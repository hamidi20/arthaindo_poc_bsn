    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value=""/>
    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;INSERT INTO POC_BSN.DWH.DIM_CUSTOMER (&#xD;&#xA;&#x9;cif,&#xD;&#xA;&#x9;customer_name,&#xD;&#xA;&#x9;customer_type,&#xD;&#xA;&#x9;customer_segment,&#xD;&#xA;&#x9;id_type,&#xD;&#xA;&#x9;id_number_dummy,&#xD;&#xA;&#x9;birth_date,&#xD;&#xA;&#x9;gender,&#xD;&#xA;&#x9;phone_dummy,&#xD;&#xA;&#x9;email_dummy,&#xD;&#xA;&#x9;address_city,&#xD;&#xA;&#x9;address_province,&#xD;&#xA;&#x9;risk_grade,&#xD;&#xA;&#x9;created_at,&#xD;&#xA;&#x9;updated_at,&#xD;&#xA;    hash_key,&#xD;&#xA;    source_system,&#xD;&#xA;    batch_id,&#xD;&#xA;    effective_date,&#xD;&#xA;    expiry_date,&#xD;&#xA;    is_active,&#xD;&#xA;    load_timestamp&#xD;&#xA;)&#xD;&#xA;SELECT&#xD;&#xA;&#x9;stg.cif,&#xD;&#xA;&#x9;stg.customer_name,&#xD;&#xA;&#x9;stg.customer_type,&#xD;&#xA;&#x9;stg.customer_segment,&#xD;&#xA;&#x9;stg.id_type,&#xD;&#xA;&#x9;stg.id_number_dummy,&#xD;&#xA;&#x9;stg.birth_date,&#xD;&#xA;&#x9;stg.gender,&#xD;&#xA;&#x9;stg.phone_dummy,&#xD;&#xA;&#x9;stg.email_dummy,&#xD;&#xA;&#x9;stg.address_city,&#xD;&#xA;&#x9;stg.address_province,&#xD;&#xA;&#x9;stg.risk_grade,&#xD;&#xA;    stg.created_at,&#xD;&#xA;    stg.updated_at,&#xD;&#xA;    MD5(&#xD;&#xA;        COALESCE(stg.customer_name,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.customer_type,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.customer_segment,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.id_type,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.id_number_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.birth_date,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.gender,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.phone_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.email_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.address_city,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.address_province,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.risk_grade,'')&#xD;&#xA;    ) AS hash_key,&#xD;&#xA;    'POSTGRESQL' AS source_system,&#xD;&#xA;    '&quot;+context.batch_id+&quot;' AS batch_id,&#xD;&#xA;    CURRENT_TIMESTAMP() AS effective_date,&#xD;&#xA;    TO_TIMESTAMP_NTZ('9999-12-31 23:59:59') AS expiry_date,&#xD;&#xA;    'Y' AS is_active,&#xD;&#xA;    CURRENT_TIMESTAMP() AS load_timestamp&#xD;&#xA;FROM POC_BSN.STAGING.STG_CUSTOMER stg&#xD;&#xA;LEFT JOIN POC_BSN.DWH.DIM_CUSTOMER tgt&#xD;&#xA;ON stg.cif = tgt.cif&#xD;&#xA;AND tgt.is_active = 'Y'&#xD;&#xA;WHERE&#xD;&#xA;    tgt.cif IS NULL&#xD;&#xA;    OR&#xD;&#xA;    MD5(&#xD;&#xA;        COALESCE(stg.customer_name,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.customer_type,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.customer_segment,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.id_type,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.id_number_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.birth_date,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.gender,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.phone_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.email_dummy,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.address_city,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.address_province,'') ||&#xD;&#xA;&#x9;&#x9;COALESCE(stg.risk_grade,'')&#xD;&#xA;    ) &lt;> tgt.hash_key&#xD;&#xA;&quot;"/>
