  <node componentName="SnowflakeRow" componentVersion="1" offsetLabelX="0" offsetLabelY="0" posX="240" posY="240" sizeX="80" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_1" show="false"/>
    <elementParameter field="TECHNICAL" name="TACOKIT_COMPONENT_ID" value="c25vd2ZsYWtlI1Nub3dmbGFrZSNSb3c" show="false"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.authenticationType" value="BASIC" show="false"/>
    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.grantType" value="CLIENT_CREDENTIALS" show="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.shareConnection" value="false" show="false"/>
    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value=""/>
    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;CREATE OR REPLACE TEMP TABLE TMP_CUSTOMER_CLEAN AS&#xD;&#xA;SELECT&#xD;&#xA;    stg.cif,&#xD;&#xA;    REGEXP_REPLACE(&#xD;&#xA;        TRIM(UPPER(stg.customer_name)),&#xD;&#xA;        '\\s+',&#xD;&#xA;        ' '&#xD;&#xA;    ) AS customer_name,&#xD;&#xA;    TRIM(UPPER(stg.customer_type)) AS customer_type,&#xD;&#xA;    TRIM(UPPER(stg.customer_segment)) AS customer_segment,&#xD;&#xA;    TRIM(UPPER(stg.id_type)) AS id_type,&#xD;&#xA;    REGEXP_REPLACE(&#xD;&#xA;        TRIM(stg.id_number_dummy),&#xD;&#xA;        '[^0-9A-Za-z]',&#xD;&#xA;        ''&#xD;&#xA;    ) AS id_number_dummy,&#xD;&#xA;    stg.birth_date,&#xD;&#xA;    CASE&#xD;&#xA;        WHEN UPPER(TRIM(stg.gender)) IN&#xD;&#xA;            ('L','LAKI-LAKI','LAKILAKI','PRIA','MALE','M')&#xD;&#xA;        THEN 'L'&#xD;&#xA;        WHEN UPPER(TRIM(stg.gender)) IN&#xD;&#xA;            ('P','PEREMPUAN','WANITA','FEMALE','F')&#xD;&#xA;        THEN 'P'&#xD;&#xA;        ELSE 'U'&#xD;&#xA;    END AS gender,&#xD;&#xA;    CASE&#xD;&#xA;        WHEN stg.phone_dummy IS NULL&#xD;&#xA;        THEN NULL&#xD;&#xA;        ELSE&#xD;&#xA;            CASE&#xD;&#xA;                WHEN REGEXP_REPLACE(&#xD;&#xA;                        stg.phone_dummy,&#xD;&#xA;                        '[^0-9]',&#xD;&#xA;                        ''&#xD;&#xA;                    ) LIKE '62%'&#xD;&#xA;&#xD;&#xA;                THEN&#xD;&#xA;                    '0' ||&#xD;&#xA;                    SUBSTR(&#xD;&#xA;                        REGEXP_REPLACE(&#xD;&#xA;                            stg.phone_dummy,&#xD;&#xA;                            '[^0-9]',&#xD;&#xA;                            ''&#xD;&#xA;                        ),&#xD;&#xA;                        3&#xD;&#xA;                    )&#xD;&#xA;                WHEN REGEXP_REPLACE(&#xD;&#xA;                        stg.phone_dummy,&#xD;&#xA;                        '[^0-9]',&#xD;&#xA;                        ''&#xD;&#xA;                    ) LIKE '8%'&#xD;&#xA;                THEN&#xD;&#xA;                    '0' ||&#xD;&#xA;                    REGEXP_REPLACE(&#xD;&#xA;                        stg.phone_dummy,&#xD;&#xA;                        '[^0-9]',&#xD;&#xA;                        ''&#xD;&#xA;                    )&#xD;&#xA;                ELSE&#xD;&#xA;                    REGEXP_REPLACE(&#xD;&#xA;                        stg.phone_dummy,&#xD;&#xA;                        '[^0-9]',&#xD;&#xA;                        ''&#xD;&#xA;                    )&#xD;&#xA;            END&#xD;&#xA;    END AS phone_dummy,&#xD;&#xA;    CASE&#xD;&#xA;        WHEN REGEXP_LIKE(&#xD;&#xA;            LOWER(TRIM(stg.email_dummy)),&#xD;&#xA;            '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'&#xD;&#xA;        )&#xD;&#xA;        THEN LOWER(TRIM(stg.email_dummy))&#xD;&#xA;        ELSE NULL&#xD;&#xA;    END AS email_dummy,&#xD;&#xA;    TRIM(UPPER(stg.address_city)) AS address_city,&#xD;&#xA;    TRIM(UPPER(stg.address_province)) AS address_province,&#xD;&#xA;    TRIM(UPPER(stg.risk_grade)) AS risk_grade,&#xD;&#xA;    stg.created_at,&#xD;&#xA;    stg.updated_at,&#xD;&#xA;    MD5(&#xD;&#xA;        COALESCE(&#xD;&#xA;            REGEXP_REPLACE(&#xD;&#xA;                TRIM(UPPER(stg.customer_name)),&#xD;&#xA;                '\\s+',&#xD;&#xA;                ' '&#xD;&#xA;            ),&#xD;&#xA;            ''&#xD;&#xA;        )&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.customer_type)),'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.customer_segment)),'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.id_type)),'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(&#xD;&#xA;            REGEXP_REPLACE(&#xD;&#xA;                TRIM(stg.id_number_dummy),&#xD;&#xA;                '[^0-9A-Za-z]',&#xD;&#xA;                ''&#xD;&#xA;            ),&#xD;&#xA;            ''&#xD;&#xA;        )&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(stg.birth_date::STRING,'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(&#xD;&#xA;            CASE&#xD;&#xA;                WHEN UPPER(TRIM(stg.gender)) IN&#xD;&#xA;                    ('L','LAKI-LAKI','LAKILAKI','PRIA','MALE','M')&#xD;&#xA;                THEN 'L'&#xD;&#xA;&#xD;&#xA;                WHEN UPPER(TRIM(stg.gender)) IN&#xD;&#xA;                    ('P','PEREMPUAN','WANITA','FEMALE','F')&#xD;&#xA;                THEN 'P'&#xD;&#xA;                ELSE 'U'&#xD;&#xA;            END,&#xD;&#xA;            ''&#xD;&#xA;        )&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(&#xD;&#xA;            CASE&#xD;&#xA;                WHEN stg.phone_dummy IS NULL&#xD;&#xA;                THEN NULL&#xD;&#xA;                ELSE&#xD;&#xA;                    CASE&#xD;&#xA;                        WHEN REGEXP_REPLACE(&#xD;&#xA;                                stg.phone_dummy,&#xD;&#xA;                                '[^0-9]',&#xD;&#xA;                                ''&#xD;&#xA;                            ) LIKE '62%'&#xD;&#xA;                        THEN&#xD;&#xA;                            '0' ||&#xD;&#xA;                            SUBSTR(&#xD;&#xA;                                REGEXP_REPLACE(&#xD;&#xA;                                    stg.phone_dummy,&#xD;&#xA;                                    '[^0-9]',&#xD;&#xA;                                    ''&#xD;&#xA;                                ),&#xD;&#xA;                                3&#xD;&#xA;                            )&#xD;&#xA;                        WHEN REGEXP_REPLACE(&#xD;&#xA;                                stg.phone_dummy,&#xD;&#xA;                                '[^0-9]',&#xD;&#xA;                                ''&#xD;&#xA;                            ) LIKE '8%'&#xD;&#xA;                        THEN&#xD;&#xA;                            '0' ||&#xD;&#xA;                            REGEXP_REPLACE(&#xD;&#xA;                                stg.phone_dummy,&#xD;&#xA;                                '[^0-9]',&#xD;&#xA;                                ''&#xD;&#xA;                            )&#xD;&#xA;                        ELSE&#xD;&#xA;                            REGEXP_REPLACE(&#xD;&#xA;                                stg.phone_dummy,&#xD;&#xA;                                '[^0-9]',&#xD;&#xA;                                ''&#xD;&#xA;                            )&#xD;&#xA;                    END&#xD;&#xA;            END,&#xD;&#xA;            ''&#xD;&#xA;        )&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(&#xD;&#xA;            CASE&#xD;&#xA;                WHEN REGEXP_LIKE(&#xD;&#xA;                    LOWER(TRIM(stg.email_dummy)),&#xD;&#xA;                    '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'&#xD;&#xA;                )&#xD;&#xA;                THEN LOWER(TRIM(stg.email_dummy))&#xD;&#xA;                ELSE NULL&#xD;&#xA;            END,&#xD;&#xA;            ''&#xD;&#xA;        )&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.address_city)),'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.address_province)),'')&#xD;&#xA;        ||&#xD;&#xA;        COALESCE(TRIM(UPPER(stg.risk_grade)),'')&#xD;&#xA;    ) AS hash_key&#xD;&#xA;FROM POC_BSN.STAGING.STG_CUSTOMER stg&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.loginTimeout" value="15" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcUrlSuffix" value=".snowflakecomputing.com" show="false"/>
