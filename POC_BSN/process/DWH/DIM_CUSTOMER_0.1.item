    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;UPDATE POC_BSN.DWH.DIM_CUSTOMER tgt&#xD;&#xA;SET&#xD;&#xA;    tgt.is_active      = 'N',&#xD;&#xA;    tgt.expiry_date    = CURRENT_TIMESTAMP()&#xD;&#xA;WHERE tgt.is_active = 'Y'&#xD;&#xA;AND EXISTS (&#xD;&#xA;    SELECT 1&#xD;&#xA;    FROM POC_BSN.STAGING.STG_CUSTOMER stg&#xD;&#xA;    WHERE stg.cif = tgt.cif&#xD;&#xA;    AND MD5(&#xD;&#xA;            COALESCE(stg.customer_name,'') ||&#xD;&#xA;            COALESCE(stg.customer_type,'') ||&#xD;&#xA;            COALESCE(stg.customer_segment,'') ||&#xD;&#xA;            COALESCE(stg.id_type,'') ||&#xD;&#xA;            COALESCE(stg.id_number_dummy,'') ||&#xD;&#xA;            COALESCE(stg.birth_date,'') ||&#xD;&#xA;            COALESCE(stg.gender,'') ||&#xD;&#xA;            COALESCE(stg.phone_dummy,'') ||&#xD;&#xA;            COALESCE(stg.email_dummy,'') ||&#xD;&#xA;            COALESCE(stg.address_city,'') ||&#xD;&#xA;            COALESCE(stg.address_province,'') ||&#xD;&#xA;            COALESCE(stg.risk_grade,'')&#xD;&#xA;        ) &lt;> tgt.hash_key&#xD;&#xA;)&#xD;&#xA;&quot;"/>
