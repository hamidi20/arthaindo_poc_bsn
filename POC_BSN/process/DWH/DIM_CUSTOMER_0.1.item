    <elementParameter field="TEXT" name="configuration.commitEvery" value="10000"/>
    <elementParameter field="CHECK" name="configuration.useSessionTimezone" value="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_2"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.__version" value="-1" show="false"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.dataStore.__version" value="-1" show="false"/>
    <metadata connector="FLOW" name="tDBRow_1"/>
    <metadata connector="LOOKUP" name="LOOKUP"/>
    <metadata connector="MERGE" name="MERGE"/>
    <metadata connector="reject" name="reject">
      <column comment="" defaultValue="" key="false" length="255" name="errorCode" nullable="false" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
