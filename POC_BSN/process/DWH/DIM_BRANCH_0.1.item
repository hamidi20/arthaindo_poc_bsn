    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.authenticationType" value="BASIC" show="false"/>
    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.grantType" value="CLIENT_CREDENTIALS" show="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.shareConnection" value="false" show="false"/>
    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value=""/>
    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;UPDATE POC_BSN.DWH.DIM_BRANCH tgt&#xD;&#xA;SET&#xD;&#xA;    tgt.is_active      = 'N',&#xD;&#xA;    tgt.expiry_date    = CURRENT_TIMESTAMP()&#xD;&#xA;WHERE tgt.is_active = 'Y'&#xD;&#xA;AND EXISTS (&#xD;&#xA;    SELECT 1&#xD;&#xA;    FROM POC_BSN.STAGING.STG_BRANCH stg&#xD;&#xA;    WHERE stg.branch_code = tgt.branch_code&#xD;&#xA;    AND MD5(&#xD;&#xA;            COALESCE(stg.branch_name,'') ||&#xD;&#xA;            COALESCE(stg.region_code,'') ||&#xD;&#xA;            COALESCE(stg.region_name,'') ||&#xD;&#xA;            COALESCE(stg.city,'') ||&#xD;&#xA;            COALESCE(stg.province,'')&#xD;&#xA;        ) &lt;> tgt.hash_key&#xD;&#xA;)&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.loginTimeout" value="15" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcUrlSuffix" value=".snowflakecomputing.com" show="false"/>
    <elementParameter field="CHECK" name="configuration.usePreparedStatement" value="false"/>
    <elementParameter field="TABLE" name="configuration.preparedStatementParameters" show="false"/>
    <elementParameter field="TEXT" name="configuration.commitEvery" value="10000"/>
    <elementParameter field="CHECK" name="configuration.useSessionTimezone" value="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_2"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.__version" value="-1" show="false"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.dataStore.__version" value="-1" show="false"/>
    <metadata connector="FLOW" name="tDBRow_1"/>
