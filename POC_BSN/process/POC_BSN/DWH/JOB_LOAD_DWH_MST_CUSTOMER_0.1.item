    <elementParameter field="MEMO_SQL" name="configuration.dataSet.sqlQuery" value="&quot;SELECT &#xD;&#xA;    \&quot;cif\&quot;,&#xD;&#xA;    \&quot;customer_name\&quot;,&#xD;&#xA;    \&quot;customer_type\&quot;,&#xD;&#xA;    \&quot;customer_segment\&quot;,&#xD;&#xA;    \&quot;id_type\&quot;,&#xD;&#xA;    \&quot;id_number_dummy\&quot;,&#xD;&#xA;    \&quot;birth_date\&quot;,&#xD;&#xA;    \&quot;gender\&quot;,&#xD;&#xA;    \&quot;phone_dummy\&quot;,&#xD;&#xA;    \&quot;email_dummy\&quot;,&#xD;&#xA;    \&quot;address_city\&quot;,&#xD;&#xA;    \&quot;address_province\&quot;,&#xD;&#xA;    \&quot;risk_grade\&quot;,&#xD;&#xA;    \&quot;created_at\&quot;,&#xD;&#xA;    \&quot;updated_at\&quot;&#xD;&#xA;FROM STAGING.MST_CUSTOMER&#xD;&#xA;WHERE&#xD;&#xA;(&#xD;&#xA;        updated_at > CAST('&quot;+globalMap.get(&quot;UPDATED_AT&quot;)+&quot;' AS TIMESTAMP)&#xD;&#xA;)&#xD;&#xA;OR&#xD;&#xA;(&#xD;&#xA;        updated_at = CAST('&quot;+globalMap.get(&quot;UPDATED_AT&quot;)+&quot;' AS TIMESTAMP)&#xD;&#xA;    AND \&quot;product_code\&quot; > '&quot;+globalMap.get(&quot;CIF&quot;)+&quot;'&#xD;&#xA;)&#xD;&#xA;ORDER BY&#xD;&#xA;    updated_at,&#xD;&#xA;    cif&quot;"/>
