    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;    account_number,&#xD;&#xA;    cif,&#xD;&#xA;    product_code,&#xD;&#xA;    branch_code,&#xD;&#xA;    account_open_date_raw,&#xD;&#xA;    account_open_date,&#xD;&#xA;    balance,&#xD;&#xA;    account_status,&#xD;&#xA;    channel_opening,&#xD;&#xA;    monthly_avg_balance,&#xD;&#xA;    last_transaction_date_raw,&#xD;&#xA;    last_transaction_date,&#xD;&#xA;    source_system,&#xD;&#xA;    created_at,&#xD;&#xA;    updated_at&#xD;&#xA;FROM public.mst_account&#xD;&#xA;WHERE&#xD;&#xA;(&#xD;&#xA;        updated_at > CAST('&quot;+globalMap.get(&quot;updated_at&quot;)+&quot;' AS TIMESTAMP)&#xD;&#xA;    OR (&#xD;&#xA;            updated_at = CAST('&quot;+globalMap.get(&quot;updated_at&quot;)+&quot;' AS TIMESTAMP)&#xD;&#xA;        AND cif > '&quot;+globalMap.get(&quot;cif&quot;)+&quot;'&#xD;&#xA;       )&#xD;&#xA;    OR (&#xD;&#xA;            updated_at = CAST('&quot;+globalMap.get(&quot;updated_at&quot;)+&quot;' AS TIMESTAMP)&#xD;&#xA;        AND cif = '&quot;+globalMap.get(&quot;cif&quot;)+&quot;'&#xD;&#xA;        AND account_number > '&quot;+globalMap.get(&quot;account_number&quot;)+&quot;'&#xD;&#xA;       )&#xD;&#xA;)&#xD;&#xA;ORDER BY&#xD;&#xA;    updated_at,&#xD;&#xA;    cif,&#xD;&#xA;    account_number&#xD;&#xA;LIMIT 10000000;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
